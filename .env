# Gemini API Keys (separated by comma)
GEMINI_API_KEYS=

# Groq API Keys (separated by comma)
GROQ_API_KEYS=

# Cài đặt engines sử dụng (gemini,groq)
ENGINES_TO_USE=gemini,groq
USE_AUTO_ENGINE_DETECTION=False

# Cấu hình cache
CACHE_DIRECTORY=cache

# Cấu hình quét API
API_SCAN_INTERVAL_MINUTES=15
ENABLE_PERIODIC_API_SCAN=True

# Thông số giới hạn xử lý
MAX_RECORDS_TO_PROCESS=20
MAX_WORKER_THREADS=2
BATCH_SIZE=2
SLEEP_BETWEEN_RECORDS=1
